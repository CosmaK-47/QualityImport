# Comma-separated ChatGPT account emails allowed to administer staff/orders.
STAFF_ADMIN_EMAILS=owner@example.com

# Local preview only. Ignored by production builds; lets localhost render the
# protected staff pages without dispatch-owned ChatGPT sign-in.
DEV_STAFF_EMAIL=owner@example.com

# Use one random value of at least 24 characters here and in
# telegram-bot/.env as ORDER_SERVICE_SECRET. Never commit the real value.
ORDER_SERVICE_SECRET=

# Used by the website when staff confirms a Telegram order. Use the same bot
# token as telegram-bot/.env, but keep the real value out of Git.
TELEGRAM_BOT_TOKEN=

# maib hosted checkout. Leave blank until maib provides sandbox credentials.
# Never commit real values. Production uses https://api.maibmerchants.md.
MAIB_CLIENT_ID=
MAIB_CLIENT_SECRET=
MAIB_SIGNATURE_KEY=
MAIB_API_BASE_URL=https://sandbox.maibmerchants.md

# Transactional order confirmations through Resend. Verify your own sending
# domain first, then keep the real API key only in local/hosted secrets.
RESEND_API_KEY=
ORDER_EMAIL_FROM=Quality Imports <orders@updates.example.com>
ORDER_EMAIL_REPLY_TO=support@example.com
